# Rename to `.env.local` for Next.js (do not commit real keys).

# Production app URL (Vercel custom domain)
NEXT_PUBLIC_APP_URL=https://spilltheteahere.vercel.app

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/spillthetea
MONGODB_DB=spillthetea
AUTH_SECRET=replace-with-a-long-random-secret

# Auth emails (Resend recommended)
RESEND_API_KEY=
AUTH_EMAIL_FROM=SpillTheTea <onboarding@resend.dev>

# Email + password is handled by the custom MongoDB auth API.

# App admin (developer) — can close ANY topic. Comma-separated MongoDB user ids.
NEXT_PUBLIC_APP_ADMIN_USER_IDS=

# Local/demo mode: your browser visitor id from localStorage key meet-greet-visitor-id
NEXT_PUBLIC_APP_ADMIN_VISITOR_IDS=

# GIF search (free key at https://developers.giphy.com/dashboard/)
GIPHY_API_KEY=

# Push notifications (optional — generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@example.com

